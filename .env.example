# Admin panel URL
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Local: call Laravel directly (recommended — do NOT use /api proxy in dev)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api

# Production (Vercel): call API directly; CORS is configured on Laravel
# NEXT_PUBLIC_API_URL=https://api.limosudcars.com/api

# Same as NEXT_PUBLIC_API_URL (used for SSR + storage image origin)
LARAVEL_API_URL=http://127.0.0.1:8000/api
